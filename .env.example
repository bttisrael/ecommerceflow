# Backend simulation
ORDERS_PER_BATCH=3000
SIMULATION_MINUTES=240
MAX_ORDERS_PER_BATCH=3000
AUTO_START_SIMULATION=true
GENERATE_INITIAL_BATCH=false

# BigQuery ingestion
# Use full table id: project.dataset.table
BIGQUERY_INGESTION_ENABLED=true
BIGQUERY_INSERT_CHUNK_SIZE=3000
BIGQUERY_BACKFILL_BATCH_SIZE=3000
MAX_BIGQUERY_BACKFILL_BATCH_SIZE=3000
BIGQUERY_ORDERS_TABLE=your-gcp-project.commerce_raw.orders
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# BigQuery dashboard/prediction query cost controls
BIGQUERY_PROJECT=your-gcp-project
BIGQUERY_PREDICTIONS_ENABLED=false
PREDICTIONS_TABLE=your-gcp-project.commerce_gold.delay_risk_predictions
PREDICTIONS_CACHE_SECONDS=900
BIGQUERY_MAX_BYTES_BILLED=100000000

# Vertex AI / scoring cost controls
# local = uses the saved sklearn model without a persistent Vertex endpoint.
# vertex = calls VERTEX_ENDPOINT_ID, but only if ALLOW_VERTEX_ENDPOINT=true.
SCORING_MODE=local
SCORING_ENABLED=true
ALLOW_VERTEX_ENDPOINT=false
BATCH_SIZE=50
DAILY_SCORING_LIMIT=300
MODEL_LOCAL_PATH=vertex_custom_model/model.joblib
FEATURE_COLUMNS_PATH=vertex_custom_model/feature_columns.json
MODEL_GCS_URI=gs://your-bucket/commerceflow/vertex_custom_model/v1
PREDICTIONS_INSERT_CHUNK_SIZE=500

# CrewAI / Claude orchestration
ANTHROPIC_API_KEY=your-anthropic-api-key
CREWAI_MODEL=anthropic/claude-sonnet-4-5

# Optional GitOps
GIT_PUSH=false
