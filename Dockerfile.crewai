FROM python:3.12-slim

WORKDIR /app

COPY requirements_crewai.txt .

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements_crewai.txt

COPY commerceflow_delay_risk_crewai_v6.py .
COPY commerceflow_crewai_cloud_runner.py .

ENV PYTHONUNBUFFERED=1

CMD ["python", "commerceflow_crewai_cloud_runner.py"]
